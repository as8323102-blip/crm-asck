# Configuración del Backend de ASCK CRM v1.8

# Selector de Proveedor: "local" (localStorage) o "supabase" (Base de datos real)
VITE_DATA_PROVIDER=local

# Credenciales de Supabase (Requeridas si VITE_DATA_PROVIDER=supabase)
# Usar SIEMPRE la clave "anon/public" (nunca la "service_role"): este es un
# proyecto de cliente (Vite) y cualquier valor VITE_* queda expuesto en el
# bundle público servido al navegador.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# En el proyecto de Supabase (Authentication → URL Configuration), configurar:
#   Site URL:            https://crm.asck.tech
#   Redirect URLs:       https://crm.asck.tech/**
# Sin esto, los flujos de Supabase Auth que dependen de redirect (reset de
# password, magic link) no funcionan en producción. El login por
# email+password que usa hoy la app no depende de esta URL, pero configurarla
# es requisito para producción de todas formas.

# Opcional. Solo usado por src/services/xampp.js (integración legado XAMPP/PHP,
# sin referencias activas en la app). Default: http://localhost/crm-api/index.php
VITE_XAMPP_API_URL=http://localhost/crm-api/index.php
